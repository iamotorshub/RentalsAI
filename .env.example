# ─── AI PROVIDER (OpenRouter) ────────────────────────────────
# Obtené tu key en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Modelo a usar (default: deepseek/deepseek-chat)
# Alternativas: deepseek/deepseek-r1 | openai/gpt-4o-mini | anthropic/claude-3-haiku
AI_MODEL=deepseek/deepseek-chat

# ─── SUPABASE (para logging de conversaciones) ───────────────
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...

# ─── SERVIDOR ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
